# ============================================
# HNF1B Database - Docker Environment Template
# ============================================
# Copy this file to .env.docker and configure your values:
#   cp .env.docker.example .env.docker
#
# NEVER commit .env.docker to version control!
# ============================================
#
# ── LOCAL FULL-STACK DEV (`make dev-up`) ──────────────────────────────────────
# `make dev-up` runs the whole stack in Docker via `--env-file .env.docker`.
# For local dev, set in your .env.docker:
#     ENVIRONMENT=development              # relaxes the prod SMTP/TLS/cookie validators
#     ADMIN_PASSWORD=<any-strong-value>    # REQUIRED — it has no default
# Keep POSTGRES_PASSWORD=hnf1b_pass to match an existing `hnf1b_postgres_data`
# volume (Postgres only honours POSTGRES_PASSWORD on the first init of an empty
# volume). The DB image is pgvector/pgvector:pg15 and the API auto-runs
# `alembic upgrade head` on startup. Once up, backfill the RAG corpus with
# `make publications-backfill`.
# ──────────────────────────────────────────────────────────────────────────────

# ============================================
# PostgreSQL Database
# ============================================
POSTGRES_USER=hnf1b_user
POSTGRES_PASSWORD=CHANGE_ME_TO_SECURE_PASSWORD
POSTGRES_DB=hnf1b_phenopackets

# ============================================
# Security (REQUIRED for Production)
# ============================================
# Generate with: openssl rand -hex 32
JWT_SECRET=CHANGE_ME_GENERATE_WITH_OPENSSL_RAND_HEX_32

# ============================================
# API Configuration
# ============================================
LOG_LEVEL_API=INFO
# For production, set your actual domains:
CORS_ORIGINS=https://hnf1b.org,https://www.hnf1b.org

# ============================================
# Public URLs (Production)
# ============================================
# API URL that the frontend will use to make requests
VITE_API_URL=https://api.hnf1b.org/api/v2

# ============================================
# NPM Integration (Production)
# ============================================
# Must match your Nginx Proxy Manager network name
# Verify with: docker network ls
NPM_SHARED_NETWORK_NAME=npm_default

# ============================================
# Image Versioning (optional)
# ============================================
IMAGE_TAG=latest

# ============================================
# Production runtime (REQUIRED for production)
# ============================================
# These are read by Wave 5c fail-closed validators in app/core/config.py.

ENVIRONMENT=production
AUTH_COOKIE_SECURE=true

# Email delivery — must be 'smtp' in production (validator refuses 'console').
# See backend/.env.example for SendGrid / Mailgun / AWS SES samples.
EMAIL_BACKEND=smtp
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=

# ============================================
# Admin Credentials (for initial setup)
# ============================================
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@hnf1b.org
ADMIN_PASSWORD=CHANGE_ME_IMMEDIATELY

# ============================================
# MCP Server Configuration
# ============================================
# Comma-separated list of allowed origins for the MCP server
HNF1B_MCP_ALLOWED_ORIGINS=https://claude.ai,https://claude.com
# Internal API base URL (service-to-service, do not expose publicly)
HNF1B_MCP_API_BASE_URL=http://hnf1b_api:8000/api/v2

# ============================================
# Host port publishing
# ============================================
# Interface the published ports below bind to. Defaults to loopback so
# Postgres/Redis/API/MCP/frontend are NOT reachable on the host's public
# interface (behind NPM, services talk over the proxy network by name, so
# loopback does not affect routing). Set to 0.0.0.0 only to deliberately
# expose these ports on all interfaces.
HOST_BIND_IP=127.0.0.1
API_PORT_HOST=8000
FRONTEND_PORT_HOST=3000
DB_PORT_HOST=5433
REDIS_PORT_HOST=6380
MCP_PORT_HOST=8788

# ============================================
# Data Import Configuration (optional)
# ============================================
# Enable automatic data import on first container startup (empty database)
# IMPORTANT: Requires GOOGLE_SHEETS_ID to be configured when enabled
#
# To enable data import:
# 1. Uncomment and set ENABLE_DATA_IMPORT=true
# 2. Set GOOGLE_SHEETS_ID to your Google Sheets document ID
#
# The container will check if the database is empty before importing.
# If data already exists, import is skipped automatically.
#
# ENABLE_DATA_IMPORT=false
# GOOGLE_SHEETS_ID=your_google_sheets_document_id
