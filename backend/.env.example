# PostgreSQL Database Configuration
DATABASE_URL=postgresql+asyncpg://hnf1b_user:hnf1b_pass@localhost:5433/hnf1b_phenopackets

# Authentication - JWT Secret
# REQUIRED: Generate a secure random secret for JWT tokens
# Generate with: openssl rand -hex 32
# Or: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET=CHANGE_ME_TO_SECURE_RANDOM_STRING

# Authentication - Default Admin User
# These credentials are used by `make db-create-admin` to create/update the admin user
# ⚠️ SECURITY: Change the admin password immediately after first login!
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@hnf1b-db.local
# ADMIN_PASSWORD is REQUIRED. Set to a strong unique password.
# The application will exit at startup if this variable is unset or empty.
# Recommended: generate with `openssl rand -base64 32`
ADMIN_PASSWORD=

# Development Settings
DEBUG=true

# ── Email / SMTP Configuration ──
# Required only when config.yaml has email.backend: "smtp"
# For console/log mode (default), these can remain empty.
#
# SendGrid:  SMTP_HOST=smtp.sendgrid.net  SMTP_USERNAME=apikey  SMTP_PASSWORD=<your-api-key>
# Mailgun:   SMTP_HOST=smtp.mailgun.org   SMTP_USERNAME=postmaster@yourdomain.com
# AWS SES:   SMTP_HOST=email-smtp.us-east-1.amazonaws.com  (use IAM SMTP credentials)
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=